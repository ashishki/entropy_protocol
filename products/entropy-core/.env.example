# Entropy Core local environment example.
# Real .env files are ignored and must not be committed.

ENTROPY_CORE_ENV=local
ENTROPY_CORE_DATABASE_URL=postgresql://entropy:entropy@localhost:5432/entropy
ENTROPY_CORE_DATA_DIR=./data/entropy-core
ENTROPY_CORE_REPORT_DIR=./artifacts/entropy-core/reports
ENTROPY_CORE_LOG_LEVEL=INFO

# Explicitly disabled by current protocol boundaries.
ENTROPY_CORE_LIVE_FEEDS_ENABLED=false
ENTROPY_CORE_BROKER_INTEGRATION_ENABLED=false
ENTROPY_CORE_LIVE_CAPITAL_ENABLED=false

