# Trader Risk Audit local environment example.
# Real .env files are ignored and must not be committed.

TRA_ENV=local
TRA_DATABASE_URL=sqlite:///./products/trader-risk-audit/local.sqlite3
TRA_UPLOAD_DIR=./products/trader-risk-audit/data/uploads
TRA_REPORT_DIR=./artifacts/trader-risk-audit/reports
TRA_LOG_LEVEL=INFO

# Optional delivery surface, disabled until validated.
TRA_TELEGRAM_DELIVERY_ENABLED=false
TRA_TELEGRAM_BOT_TOKEN=
TRA_TELEGRAM_CHAT_ID=

# Explicitly disabled for MVP.
TRA_LIVE_BROKER_API_ENABLED=false
TRA_ORDER_BLOCKING_ENABLED=false

