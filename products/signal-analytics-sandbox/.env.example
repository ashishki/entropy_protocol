# Signal Analytics Sandbox local environment example.
# Real .env files are ignored and must not be committed.

SAS_ENV=local
SAS_DATABASE_URL=sqlite:///./products/signal-analytics-sandbox/local.sqlite3
SAS_SOURCE_LEDGER_DIR=./products/signal-analytics-sandbox/data/source-ledgers
SAS_REPORT_DIR=./artifacts/signal-analytics-sandbox/reports
SAS_LOG_LEVEL=INFO

# Public-source validation only.
SAS_PUBLIC_SOURCES_ONLY=true
SAS_PRIVATE_GROUP_SCRAPING_ENABLED=false

# Optional delivery or API values. Leave empty until explicitly needed.
SAS_TELEGRAM_BOT_TOKEN=
SAS_X_API_BEARER_TOKEN=

